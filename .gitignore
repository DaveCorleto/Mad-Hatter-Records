cat > .gitignore <<'EOF'
# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
firebase-debug.log*
firebase-debug.*.log*

# Firebase cache
.firebase/

# Firebase config
# .firebaserc

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage and build artifacts
coverage
.nyc_output
.grunt
bower_components
.lock-wscript
build/Release
lib-cov

# Dependency directories
node_modules/
gear-api/node_modules/

# Optional caches
.npm
.eslintcache

# Optional REPL history
.node_repl_history

# Package archives
*.tgz

# Yarn integrity
.yarn-integrity

# Environment files
.env

# macOS
.DS_Store

# dataconnect generated files
.dataconnect
EOF
.gitconfig
.gitconfig_system_empty
